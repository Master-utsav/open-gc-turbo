# =========================================================
# BASE
# =========================================================
FROM node:22-alpine AS base

RUN apk add --no-cache libc6-compat

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN corepack enable

# =========================================================
# PRUNER
# =========================================================
FROM base AS pruner

WORKDIR /app

COPY . .

RUN pnpm dlx turbo prune web --docker

# =========================================================
# INSTALLER
# =========================================================
FROM base AS installer

WORKDIR /app

COPY --from=pruner /app/out/json/ .

RUN pnpm install --frozen-lockfile

# =========================================================
# BUILDER
# =========================================================
FROM base AS builder

WORKDIR /app

COPY --from=installer /app/node_modules ./node_modules
COPY --from=installer /app/ .
COPY --from=pruner /app/out/full/ .

# NEXT_PUBLIC_* must be declared as ARG + ENV before build
# Next.js webpack inlines these at compile time — runtime env won't work
ARG NEXT_PUBLIC_HTTP_URL
ARG NEXT_PUBLIC_WS_URL
ARG NEXT_PUBLIC_TENOR_API_KEY

ENV NEXT_PUBLIC_HTTP_URL=$NEXT_PUBLIC_HTTP_URL
ENV NEXT_PUBLIC_WS_URL=$NEXT_PUBLIC_WS_URL
ENV NEXT_PUBLIC_TENOR_API_KEY=$NEXT_PUBLIC_TENOR_API_KEY

# =========================================================
# PRISMA GENERATE
# =========================================================
RUN pnpm run db:generate

# =========================================================
# BUILD APP + DEPENDENCIES
# =========================================================
RUN pnpm dlx turbo run build --filter=web...

# =========================================================
# RUNNER
# =========================================================
FROM node:22-alpine AS runner

WORKDIR /app

RUN apk add --no-cache libc6-compat

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

RUN addgroup --system --gid 1001 nodejs
RUN adduser --system --uid 1001 nextjs

COPY --from=builder /app/apps/web/.next/standalone ./
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
# COPY --from=builder /app/apps/web/public ./apps/web/public

USER nextjs

EXPOSE 3000

CMD ["node", "apps/web/server.js"]